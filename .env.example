# Ditat TMS API — copy this file to <project>/.env and fill in.
DITAT_BASE_URL=https://tmsapi01.ditat.net
DITAT_ACCOUNT_ID=your_account_id
DITAT_CLIENT_ID=your_client_id
DITAT_CLIENT_SECRET=your_client_secret

# Optional
DITAT_MAX_SHIPMENTS=3
DITAT_DOWNLOAD_DIR=./downloads

# Optional path overrides — if unset, scripts default to $CLAUDE_PROJECT_DIR
# DITAT_STATE_DIR=./
# DITAT_REPORTS_DIR=./reports
# DITAT_TOKEN_CACHE_DIR=./
