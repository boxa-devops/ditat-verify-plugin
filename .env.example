# Plugin (local) config — copy to <project>/.env and fill in.
# The plugin talks to YOUR verification server, not to Ditat directly.

DITAT_SERVER_URL=https://your-server.example.run.app
# Must match the server's DITAT_SERVER_API_KEY. Leave blank only if the server runs open.
DITAT_SERVER_API_KEY=your_shared_api_key

# Telegram delivery (optional) — when both are set, `finalize` sends the summary
# + the .docx to this channel/group. Bot must be an admin/member of the chat.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...        # from @BotFather
# TELEGRAM_CHAT_ID=-1001234567890             # channel/group id, or @channelusername

# Optional
DITAT_DOWNLOAD_DIR=./downloads

# Optional path overrides — if unset, scripts default to $CLAUDE_PROJECT_DIR
# DITAT_STATE_DIR=./
# DITAT_REPORTS_DIR=./reports
# DITAT_RULES_PATH=./scripts/rules.yaml
